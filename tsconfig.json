{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": "src",
    "removeComments": true,
    "typeRoots": [
      "node_modules/@types",
      "src/@types"
    ],
    "lib": [
      "esnext",
    ],
  },
}