{
  "name": "yoda-api",
  "version": "0.0.1",
  "description": "An api for yoda-fits shortener. A AI based title summarizer.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_PATH=./src ts-node-dev --respawn --transpile-only --poll ./src/index.ts",
    "start": "cross-env NODE_PATH=./dist node ./dist/index.js",
    "lint": "prettier --check --plugin-search-dir=. . && eslint ./src/*",
    "format": "prettier --write --plugin-search-dir=. .",
    "db": "prisma generate",
    "db:mig": "prisma migrate dev --name",
    "db:push": "prisma db push",
    "db:dev": "prisma studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irg1008/Yoda-API.git"
  },
  "keywords": [
    "ai",
    "intergalactic",
    "shortener"
  ],
  "author": "@gázquez",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/irg1008/Yoda-API/issues"
  },
  "homepage": "https://github.com/irg1008/Yoda-API#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.1",
    "eslint": "^8.18.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.7.1",
    "prisma": "^3.15.2",
    "ts-node": "^10.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@prisma/client": "^3.15.2",
    "fastify": "^4.1.0",
    "gpt-3-encoder": "^1.1.3",
    "openai": "^3.0.0"
  }
}
